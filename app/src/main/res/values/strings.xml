    <!-- ============================ Onboarding ============================ -->
    <string name="onboarding_welcome_title">Welcome to Pathline</string>
    <string name="onboarding_welcome_body">Pathline keeps a private, on-device timeline of the places you visit and the trips between them — no account, and your location never leaves your phone.</string>
    <string name="onboarding_permissions_title">A few permissions</string>
    <string name="onboarding_permissions_body">Pathline records where you go and how you get there. It needs a few permissions to work correctly.</string>
    <string name="perm_notifications_title">Notifications</string>
    <string name="perm_notifications_desc">Shows a status notice while recording is active.</string>
    <string name="perm_location_title">Location</string>
    <string name="perm_location_desc">Records where you go so Pathline can build your timeline.</string>
    <string name="perm_activity_title">Physical activity</string>
    <string name="perm_activity_desc">Detects when you\'re moving and how you travel, so recording stays light on the battery.</string>
    <string name="onboarding_background_title">Keep recording in the background</string>
    <string name="onboarding_background_body">To build a complete timeline, location access needs to be set to \"Allow all the time\" so Pathline keeps recording when the app is closed. Android asks for this separately on the next screen.</string>
    <string name="onboarding_oem_autostart_title">Keep Pathline running</string>
    <string name="onboarding_oem_autostart_body">Your device might prevent Pathline from running in the background or starting automatically, which can interrupt location recording. To help keep your timeline complete, you can allow Pathline to auto-start (sometimes called auto-launch or background startup) in your device settings.</string>
    <string name="onboarding_oem_autostart_action_open">Open auto-start settings</string>
