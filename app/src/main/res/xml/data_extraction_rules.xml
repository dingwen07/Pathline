<?xml version="1.0" encoding="utf-8"?>
<!--
   The database is now encrypted by a device-bound Android Keystore key and backed up via the app's
   own SAF backup (a folder the user chooses). Android cloud auto-backup of the DB is therefore
   excluded: the ciphertext could never be decrypted on another device, so it would only waste the
   25 MB quota. The Keystore-wrapped passphrase / backup DEK live in noBackupFilesDir, which Android
   excludes automatically. A full device-to-device transfer still copies everything (the Keystore
   keys migrate with it).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pathline.db" />
        <exclude domain="database" path="pathline.db-wal" />
        <exclude domain="database" path="pathline.db-shm" />
    </cloud-backup>
    <device-transfer />
</data-extraction-rules>
