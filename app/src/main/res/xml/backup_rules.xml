<?xml version="1.0" encoding="utf-8"?>
<!--
   Legacy auto-backup rules (API < 31). The database is encrypted by a device-bound Keystore key and
   backed up through the app's own SAF backup, so the DB is excluded from cloud auto-backup (its
   ciphertext is undecryptable on another device). See data_extraction_rules.xml for the API 31+ form.
-->
<full-backup-content>
    <exclude domain="database" path="pathline.db" />
    <exclude domain="database" path="pathline.db-wal" />
    <exclude domain="database" path="pathline.db-shm" />
</full-backup-content>
