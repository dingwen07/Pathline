<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Motion / activity recognition -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Foreground location service that runs for the whole tracking session -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Network / device-state enrichment -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Re-arm recording after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <!--
      Scoped package visibility (Android 11+): see the SAF DocumentsProvider apps so we can resolve a
      backup/GPX destination's provider to a friendly app name.
    -->
    <queries>
        <intent>
            <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
        </intent>
    </queries>

    <application
        android:name=".PathlineApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pathline">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Pathline">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Google Maps / Places API key, injected from local.properties (see build.gradle.kts) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- Foreground location recorder; stays alive for the whole tracking session, dropping to a
             low-power cadence while stationary rather than stopping. -->
        <service
            android:name=".service.LocationRecorderService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Activity Recognition transitions (low-power heartbeat) -->
        <receiver
            android:name=".service.ActivityTransitionReceiver"
            android:exported="false" />

        <!-- Geofence exit events (resume recording when leaving a parked location) -->
        <receiver
            android:name=".service.GeofenceBroadcastReceiver"
            android:exported="false" />

        <!-- Batched location deliveries -->
        <receiver
            android:name=".service.LocationUpdatesReceiver"
            android:exported="false" />

        <!-- Action buttons on the "recording turned off" alert notification -->
        <receiver
            android:name=".service.RecordingActionReceiver"
            android:exported="false" />

        <!-- Re-arm AR + geofences after reboot -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
            </intent-filter>
        </receiver>

        <!-- Shares diagnostic log files from filesDir/logs via a content URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- WorkManager is configured on-demand via PathlineApp (Configuration.Provider); remove
             the default initializer so Hilt's worker factory is used. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
