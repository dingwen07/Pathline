<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Motion / activity recognition -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Foreground location service that runs for the whole tracking session -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Network / device-state enrichment -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Re-arm recording after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <!--
      Coarse gate for the whole data provider: an install-time (normal) permission, auto-granted to any
      app that declares <uses-permission> for it - no runtime prompt. It is required on the provider
      below, so an app that did not opt in can neither resolve nor query the API at all. This only marks
      "this app intends to use the Pathline API"; the per-collection READ_* permissions below (dangerous,
      runtime, user-approved) remain the actual data gates.
    -->
    <permission
        android:name="net.extrawdw.apps.locationhistory.permission.API"
        android:protectionLevel="normal"
        android:label="@string/perm_api_label"
        android:description="@string/perm_api_description" />

    <!--
      On-device data-API permissions (see PathlineProvider / PathlineContract). READ_TIMELINE_ROUTE and
      READ_LOCATION_HISTORY share a group on purpose: both expose the precise path, so they grant and
      revoke as one tier; READ_TIMELINE stays outside it so a timeline-only caller never gains routes.
    -->
    <permission-group
        android:name="net.extrawdw.apps.locationhistory.permission-group.LOCATION_HISTORY"
        android:icon="@drawable/ic_perm_location_history"
        android:label="@string/perm_group_location_history_label"
        android:description="@string/perm_group_location_history_description" />

    <permission
        android:name="net.extrawdw.apps.locationhistory.permission.READ_TIMELINE"
        android:protectionLevel="dangerous"
        android:icon="@drawable/ic_perm_timeline"
        android:label="@string/perm_read_timeline_label"
        android:description="@string/perm_read_timeline_description" />

    <permission
        android:name="net.extrawdw.apps.locationhistory.permission.READ_TIMELINE_ROUTE"
        android:protectionLevel="dangerous"
        android:permissionGroup="net.extrawdw.apps.locationhistory.permission-group.LOCATION_HISTORY"
        android:icon="@drawable/ic_perm_route"
        android:label="@string/perm_read_timeline_route_label"
        android:description="@string/perm_read_timeline_route_description" />

    <permission
        android:name="net.extrawdw.apps.locationhistory.permission.READ_LOCATION_HISTORY"
        android:protectionLevel="dangerous"
        android:permissionGroup="net.extrawdw.apps.locationhistory.permission-group.LOCATION_HISTORY"
        android:icon="@drawable/ic_perm_location_history"
        android:label="@string/perm_read_location_history_label"
        android:description="@string/perm_read_location_history_description" />

    <permission
        android:name="net.extrawdw.apps.locationhistory.permission.READ_EXTENDED_HISTORY"
        android:protectionLevel="dangerous"
        android:icon="@drawable/ic_perm_extended_history"
        android:label="@string/perm_read_extended_history_label"
        android:description="@string/perm_read_extended_history_description" />

    <!--
      Scoped package visibility (Android 11+): see the SAF DocumentsProvider apps so we can resolve a
      backup/GPX destination's provider to a friendly app name.
    -->
    <queries>
        <intent>
            <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
        </intent>
        <!--
          OEM "auto-start" / "auto-launch" managers (Chinese skins).
        -->
        <package android:name="com.huawei.systemmanager" />
        <package android:name="com.hihonor.systemmanager" />
        <package android:name="com.coloros.safecenter" />
        <package android:name="com.oppo.safe" />
        <package android:name="com.vivo.permissionmanager" />
        <package android:name="com.iqoo.secure" />
        <package android:name="com.oneplus.security" />
        <package android:name="com.letv.android.letvsafe" />
        <package android:name="com.meizu.safe" />
        <package android:name="com.asus.mobilemanager" />
    </queries>

    <application
        android:name=".PathlineApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pathline">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Pathline">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- "Access to Pathline data" manager -->
        <activity
            android:name=".ui.ApiAccessActivity"
            android:exported="false"
            android:label="@string/api_access_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Pathline" />

        <!-- First-run onboarding for the data API. Exported so another app can fire
             PathlineContract.Actions.REQUEST_API_ACCESS to ask the user to turn access on; it only
             shows UI (the user decides) and returns no result. -->
        <activity
            android:name=".ui.ApiAccessOnboardingActivity"
            android:exported="true"
            android:label="@string/api_access_title"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Pathline">
            <intent-filter>
                <action android:name="net.extrawdw.apps.locationhistory.action.REQUEST_API_ACCESS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Show rationale for data access -->
        <activity
            android:name=".PermissionUsageActivity"
            android:exported="true"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE"
            android:theme="@style/Theme.Pathline">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Google Maps / Places API key, injected from local.properties (see build.gradle.kts) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- Foreground location recorder; stays alive for the whole tracking session, dropping to a
             low-power cadence while stationary rather than stopping. -->
        <service
            android:name=".service.LocationRecorderService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Activity Recognition transitions (low-power heartbeat) -->
        <receiver
            android:name=".service.ActivityTransitionReceiver"
            android:exported="false" />

        <!-- Geofence exit events (resume recording when leaving a parked location) -->
        <receiver
            android:name=".service.GeofenceBroadcastReceiver"
            android:exported="false" />

        <!-- Batched location deliveries -->
        <receiver
            android:name=".service.LocationUpdatesReceiver"
            android:exported="false" />

        <!-- Action buttons on the "recording turned off" alert notification -->
        <receiver
            android:name=".service.RecordingActionReceiver"
            android:exported="false" />

        <!-- Re-arm AR + geofences after reboot -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
            </intent-filter>
        </receiver>

        <!-- Shares diagnostic log files from filesDir/logs via a content URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          API for other apps (timeline + recorded samples). Exported, but android:permission gates the
          whole provider behind the auto-granted ".permission.API" above: a caller that did not declare
          it cannot resolve or reach the provider. Past that gate, every query additionally enforces a
          custom runtime permission on the caller in code (PathlineProvider), and reads older than 30
          days require the extended-history permission on top. The authority is applicationId +
          ".provider"; see PathlineContract for the public surface.
        -->
        <provider
            android:name=".api.PathlineProvider"
            android:authorities="${applicationId}.provider"
            android:permission="net.extrawdw.apps.locationhistory.permission.API"
            android:exported="true" />

        <!-- WorkManager is configured on-demand via PathlineApp (Configuration.Provider); remove
             the default initializer so Hilt's worker factory is used. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
